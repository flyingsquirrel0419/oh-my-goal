{
  "name": "oh-my-goal",
  "version": "1.0.0",
  "description": "Codex-style /goal autonomous loop plugin for OpenCode.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    ".opencode/commands/goal.md",
    ".opencode/plugins/oh-my-goal.js",
    "docs/demo.svg",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "goal",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyingsquirrel0419/oh-my-goal.git"
  },
  "bugs": {
    "url": "https://github.com/flyingsquirrel0419/oh-my-goal/issues"
  },
  "homepage": "https://github.com/flyingsquirrel0419/oh-my-goal#readme",
  "license": "Apache-2.0",
  "dependencies": {
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.35"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.14.35",
    "@types/node": "^22.15.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">=20"
  }
}
